+/-! ### `iRedDescent` BUNDLE twins of the principal-cut descent (lap 150)
+
+The §14.254 general chain reduction (`genReduct_botSucc_chain`, `Crux2Blueprint`) consumes the
+principal-cut descent as the `iRedDescent` BUNDLE (`dg_le` + `otil_lt` + `nf`), not the combined `iord`
+form — because the OUTER chain replace (`descent_step_K_replace`) folds the premise reduct's `idg`/`õ`
+SEPARATELY (a `max`-fold of degrees, a `nadd`-fold of pre-ordinals). The combined `icmp (iord …) = 0` does
+NOT split, so these bundle twins of `iord_descent_iCritReduct`/`_object` are genuinely needed: they stop
+ONE step before `iord_descent_cut` combines the two halves, returning the pair instead. -/
+
+set_option maxHeartbeats 1000000 in
+/-- **`iRedDescent` bundle for the cut-reduct object** — the bundle twin of `iord_descent_iCritReduct`
+(stops before `iord_descent_cut`). `dg_le` from `idg_zK_iCritReduct_lt` (the strict `+1 ≤` weakened to `≤`),
+`otil_lt` from `icmp_omega_pow_nadd_lt`, `nf` from `isNF_inadd` of the two `ω`-powers. -/
+lemma iRedDescent_iCritReduct {s' r' d0 d1 d : V}
+    (h0o : icmp (iotil d0) (iotil d) = 0) (h1o : icmp (iotil d1) (iotil d) = 0)
+    (hr' : r' + 1 ≤ idg d) (h0g : idg d0 ≤ idg d) (h1g : idg d1 ≤ idg d) (hpos : 1 ≤ idg d)
+    (h0nf : isNF (iotil d0)) (h1nf : isNF (iotil d1)) :
+    iRedDescent (zK s' r' (iCritReductSeq d0 d1)) d :=
+  ⟨le_trans le_self_add (idg_zK_iCritReduct_lt hr' h0g h1g hpos),
+   iotil_zK_iCritReduct_lt h0o h1o,
+   isNF_iotil_zK_iCritReduct h0nf h1nf⟩
+
+set_option maxHeartbeats 1000000 in
+/-- **`iRedDescent` bundle for the double-replace cut-reduct** — the bundle twin of
+`iord_descent_iCritReduct_object`. `r' = r-1` (`sub_add_self_of_le`), `r ≤ idg(K^r ds)` (`r_le_idg_zK`);
+the two `iCritAux` auxiliaries' NF come from the `seqUpdate`-entry NFs (`isNF_iseqNaddIdg`). -/
+lemma iRedDescent_iCritReduct_object {s r ds i j v w : V}
+    (hds : Seq ds) (hr : 1 ≤ r)
+    (hi : i < lh ds) (hj : j < lh ds)
+    (hvlt : icmp (iotil v) (iotil (znth ds i)) = 0)
+    (hwlt : icmp (iotil w) (iotil (znth ds j)) = 0)
+    (hvg : idg v ≤ idg (znth ds i)) (hwg : idg w ≤ idg (znth ds j))
+    (hNF : ∀ n, isNF (iotil (znth ds n))) (hNFv : isNF (iotil v)) (hNFw : isNF (iotil w)) :
+    iRedDescent (iCritReduct (zK s r ds) i j v w) (zK s r ds) := by
+  have hred : iCritReduct (zK s r ds) i j v w
+      = zK s (r - 1) (iCritReductSeq (iCritAux (zK s r ds) i v) (iCritAux (zK s r ds) j w)) := by
+    simp [iCritReduct]
+  have hrd : r ≤ idg (zK s r ds) := r_le_idg_zK s r ds hds
+  have hpos : 1 ≤ idg (zK s r ds) := le_trans hr hrd
+  have hr' : (r - 1) + 1 ≤ idg (zK s r ds) := by rw [sub_add_self_of_le hr]; exact hrd
+  have hNFiv : isNF (iotil (iCritAux (zK s r ds) i v)) := isNF_iotil_iCritAux hi hNF hNFv
+  have hNFjw : isNF (iotil (iCritAux (zK s r ds) j w)) := isNF_iotil_iCritAux hj hNF hNFw
+  rw [hred]
+  exact iRedDescent_iCritReduct
+    (iotil_iCritAux_lt hds hi hvlt hNF hNFv) (iotil_iCritAux_lt hds hj hwlt hNF hNFw)
+    hr' (idg_iCritAux_le hds hi hvg) (idg_iCritAux_le hds hj hwg) hpos hNFiv hNFjw
+
+/-- **`iRedDescent` bundle for `iRcrit`** — bundle twin of `iord_descent_iRcrit_of_redex`. -/
+lemma iRedDescent_iRcrit_of_redex {s r ds : V} {ρ : V → V}
+    (hds : Seq ds) (hr : 1 ≤ r)
+    (hex : ∃ c < (⟪lh (zKseq (zK s r ds)), lh (zKseq (zK s r ds))⟫ : V),
+      isRedexPair (zKseq (zK s r ds)) c)
+    (hNF : ∀ n, isNF (iotil (znth ds n)))
+    (hρlt_i : icmp (iotil (ρ (redexI (zK s r ds)))) (iotil (znth ds (redexI (zK s r ds)))) = 0)
+    (hρlt_j : icmp (iotil (ρ (redexJ (zK s r ds)))) (iotil (znth ds (redexJ (zK s r ds)))) = 0)
+    (hρg_i : idg (ρ (redexI (zK s r ds))) ≤ idg (znth ds (redexI (zK s r ds))))
+    (hρg_j : idg (ρ (redexJ (zK s r ds))) ≤ idg (znth ds (redexJ (zK s r ds))))
+    (hρNF_i : isNF (iotil (ρ (redexI (zK s r ds)))))
+    (hρNF_j : isNF (iotil (ρ (redexJ (zK s r ds))))) :
+    iRedDescent (iRcrit (zK s r ds) ρ) (zK s r ds) := by
+  have hrc : isRedexPair (zKseq (zK s r ds)) (redexCode (zK s r ds)) := redexCode_isRedexPair hex
+  simp only [zKseq_zK] at hrc
+  obtain ⟨hIJ, hJlh, -, -, -⟩ := hrc
+  have hJlh' : redexJ (zK s r ds) < lh ds := hJlh
+  have hIlh' : redexI (zK s r ds) < lh ds := lt_trans hIJ hJlh
+  exact iRedDescent_iCritReduct_object hds hr hIlh' hJlh'
+    hρlt_i hρlt_j hρg_i hρg_j hNF hρNF_i hρNF_j
+
+
